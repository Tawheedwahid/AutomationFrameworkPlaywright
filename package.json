{
  "name": "automation-framework-playwright",
  "version": "1.0.0",
  "description": "Enterprise Playwright Automation Framework for demoqa.com",
  "author": "Tawheed Wani",
  "license": "MIT",
  "scripts": {
    "test": "cross-env ENV=qa playwright test",
    "test:dev": "cross-env ENV=dev playwright test",
    "test:staging": "cross-env ENV=staging playwright test",
    "test:chrome": "cross-env BROWSER=chromium playwright test",
    "test:firefox": "cross-env BROWSER=firefox playwright test",
    "test:webkit": "cross-env BROWSER=webkit playwright test",
    "test:headed": "playwright test --headed",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "report": "npm run allure:generate && npm run allure:open",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf allure-results allure-report test-results"
  },
  "devDependencies": {
    "@playwright/test": "1.44.1",
    "@types/node": "20.14.2",
    "allure-playwright": "3.0.0-beta.3",
    "cross-env": "7.0.3",
    "dotenv": "16.4.5",
    "rimraf": "5.0.7",
    "typescript": "5.4.5",
    "winston": "3.13.0"
  }
}
